generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db" // É uma boa prática usar uma variável de ambiente aqui
}

// Modelo para usuários, essencial para autenticação (auth)
model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  password     String // Lembre-se de armazenar a senha com hash, não em texto plano
  createdAt    DateTime      @default(now())
  transactions Transaction[]
  categories   Category[]
}

// Modelo para transações financeiras
model Transaction {
  id              String          @id @default(uuid())
  description     String
  amount          Float
  type            TransactionType
  date            DateTime
  createdAt       DateTime        @default(now())
  user            User            @relation(fields: [userId], references: [id])
  userId          String
  category        Category        @relation(fields: [categoryId], references: [id])
  categoryId      String
  paymentMethod   PaymentMethod   @relation(fields: [paymentMethodId], references: [id])
  paymentMethodId String
}

model Category {
  id           String        @id @default(uuid())
  name         String
  user         User          @relation(fields: [userId], references: [id])
  userId       String
  transactions Transaction[]

  @@unique([name, userId])
}

// Modelo para métodos de pagamento, pode estar relacionado a "EMV" ou outros tipos de cartão
model PaymentMethod {
  id           String        @id @default(uuid())
  name         String // Ex: "Cartão de Crédito", "Débito", "PIX"
  brand        String // Ex: "Visa", "Mastercard"
  transactions Transaction[]
}

enum TransactionType {
  INCOME
  EXPENSE
}